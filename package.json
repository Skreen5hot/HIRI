{
  "name": "json-ld-deterministic-service-template",
  "version": "0.1.0",
  "description": "A minimal template for building deterministic JSON-LD transformation services",
  "type": "module",
  "main": "dist/kernel/index.js",
  "types": "dist/kernel/index.d.ts",
  "scripts": {
    "build": "tsc",
    "build:tests": "tsc -p tsconfig.test.json",
    "start": "node dist/kernel/index.js",
    "test": "npm run build:tests && node dist-tests/tests/run-tests.js",
    "test:purity": "npm run build:tests && node dist-tests/scripts/ensure-kernel-purity.js",
    "clean": "rimraf dist dist-tests",
    "build:demo": "node esbuild.config.mjs && node -e \"const fs=require('fs');fs.copyFileSync('node_modules/oxigraph/web.js','dist/oxigraph-web.js');fs.copyFileSync('node_modules/oxigraph/web_bg.wasm','dist/web_bg.wasm');console.log('Copied oxigraph WASM files')\""
  },
  "keywords": [
    "json-ld",
    "deterministic",
    "edge-computing",
    "architecture",
    "offline-first",
    "template"
  ],
  "repository": {
    "type": "git",
    "url": ""
  },
  "homepage": "",
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/jsonld": "^1.5.15",
    "@types/node": "^22.0.0",
    "esbuild": "^0.27.3",
    "rimraf": "^6.0.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@noble/ed25519": "^3.0.0",
    "jsonld": "^9.0.0",
    "oxigraph": "^0.5.5"
  }
}
